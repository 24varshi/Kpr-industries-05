rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'gsrinivasarao9699@gmail.com' ||
        (isVerified() && (
          exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
          exists(/databases/$(database)/documents/admin_emails/$(request.auth.token.email))
        ))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'category', 'image']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.category is string && data.category.size() > 0 &&
             data.image is string && data.image.size() > 0 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 2000)) &&
             (!('createdAt' in data) || (data.createdAt == request.time || data.createdAt is timestamp));
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['customerName', 'customerPhone', 'customerAddress', 'items', 'totalAmount']) &&
             data.customerName is string && data.customerName.size() > 0 &&
             data.customerPhone is string && data.customerPhone.size() >= 10 &&
             data.customerAddress is string && data.customerAddress.size() > 0 &&
             data.items is list && data.items.size() > 0 &&
             data.totalAmount is number && data.totalAmount >= 0;
    }

    function isValidSettings(data) {
      return (!('address' in data) || (data.address is string && data.address.size() <= 500)) &&
             (!('phone' in data) || (data.phone is string && data.phone.size() <= 20)) &&
             (!('whatsapp' in data) || (data.whatsapp is string && data.whatsapp.size() <= 20)) &&
             (!('email' in data) || (data.email is string && data.email.size() <= 100)) &&
             (!('announcement' in data) || (data.announcement is string && data.announcement.size() <= 200));
    }

    // --- Collection Rules ---

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() && isValidSettings(incoming()) && isValidId(settingId);
    }

    match /admin_emails/{email} {
      allow read, write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true; // Public catalog
      allow create: if isAdmin() && isValidProduct(incoming()) && isValidId(productId);
      allow update: if isAdmin() && isValidProduct(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'price', 'category', 'image', 'description', 'updatedAt'])
      );
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if isValidOrder(incoming()) && isValidId(orderId) && 
                      (!('createdAt' in incoming()) || incoming().createdAt == request.time);
      allow get: if isAdmin();
      allow list: if isAdmin();
      allow update: if isAdmin() && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
        incoming().status in ['pending', 'confirmed', 'delivered', 'cancelled']
      );
      allow delete: if isAdmin();
    }

    match /admins/{userId} {
      allow read: if isAdmin();
      allow write: if isAdmin() && isValidId(userId);
    }
  }
}
