{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A kitchen product for sale",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "image"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "customerAddress": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "delivered", "cancelled"] },
        "paymentMethod": { "type": "string", "enum": ["COD", "UPI"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "customerPhone", "customerAddress", "items", "totalAmount"]
    },
    "Admin": {
      "title": "Admin",
      "description": "An administrative user",
      "type": "object",
      "properties": {
        "email": { "type": "string" }
      },
      "required": ["email"]
    },
    "Settings": {
      "title": "Store Settings",
      "description": "Global store configuration and contact details",
      "type": "object",
      "properties": {
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "whatsapp": { "type": "string" },
        "email": { "type": "string" },
        "announcement": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product catalog"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/admins/{userId}": {
      "schema": "Admin",
      "description": "Users with administrative privileges"
    },
    "/settings/{settingId}": {
      "schema": "Settings",
      "description": "Global store configuration"
    }
  }
}
